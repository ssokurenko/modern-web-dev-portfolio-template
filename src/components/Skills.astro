---
const skills = [
	"TypeScript", "React", "Astro", "Tailwind CSS", "Node.js", 
	"Next.js", "PostgreSQL", "Docker", "AWS", "GraphQL"
];
---
<div class="bg-yellow-400 py-6 overflow-hidden border-y-4 border-black">
	<div class="flex whitespace-nowrap animate-marquee">
		{Array(4).fill(0).map(() => (
			<div class="flex items-center">
				{skills.map(skill => (
					<span class="text-4xl md:text-6xl font-black text-black mx-8 uppercase">
						{skill}
					</span>
					<span class="text-4xl md:text-6xl text-black">/</span>
				))}
			</div>
		))}
	</div>
</div>

<style>
	.animate-marquee {
		animation: marquee 30s linear infinite;
	}
	@keyframes marquee {
		0% { transform: translateX(0); }
		100% { transform: translateX(-50%); }
	}
</style>
