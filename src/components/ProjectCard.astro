---
interface Props {
	title: string;
	category: string;
	image: string;
	link: string;
}

const { title, category, image, link } = Astro.props;
---
<a href={link} class="group block relative border-4 border-white overflow-hidden bg-zinc-900 transition-all hover:-translate-y-2 hover:shadow-[12px_12px_0px_0px_rgba(252,211,77,1)]">
	<div class="aspect-video overflow-hidden">
		<div class={`w-full h-full ${image} grayscale group-hover:grayscale-0 transition-all duration-500 scale-100 group-hover:scale-110`}></div>
	</div>
	<div class="p-6">
		<span class="text-yellow-400 font-bold text-sm uppercase tracking-widest">{category}</span>
		<h3 class="text-3xl font-bold mt-2 text-white uppercase">{title}</h3>
		<div class="mt-4 flex items-center gap-2 text-zinc-400 group-hover:text-white transition-colors">
			<span>Explore Project</span>
			<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:translate-x-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
			</svg>
		</div>
	</div>
</a>
